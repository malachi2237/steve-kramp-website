---
import { getResources, toDisplayResources } from "../lib/sonicjs";
import PageLayout from "../layouts/pagelayout.astro";
import PageSection from "../components/generic/pagesection.astro";
import Multicard from "../components/generic/multicard.astro";
import Resourcecard from "../components/resourcecard.astro";

const resources = await getResources().then(toDisplayResources);
// /files/uploads/
---

<PageLayout title="Resources">
    <PageSection>
        <h1>Resources</h1>
        <Multicard elementMinSize="24rem">
            {
                resources.map((resource) => (
                    <Resourcecard resource={resource}/>
                ))
            }
        </div>
    </PageSection>
</PageLayout>
