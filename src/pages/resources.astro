---
import libertinus400 from "@fontsource/libertinus-sans/files/libertinus-sans-latin-400-normal.woff2?url";
import overpass400 from "@fontsource/overpass/files/overpass-latin-400-normal.woff2?url";
import { getResources, toDisplayResources } from "../lib/sonicjs";
import PageLayout from "../layouts/pagelayout.astro";
import PageSection from "../components/generic/pagesection.astro";
import Multicard from "../components/generic/multicard.astro";
import Resourcecard from "../components/resourcecard.astro";

const rawResources = await getResources()
console.log(rawResources)
const resources = toDisplayResources(rawResources)
// /files/uploads/
/* export const prerender = false; */

---

<PageLayout title="Resources">
    <Fragment slot="head">
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href={libertinus400}
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href={overpass400}
            crossorigin="anonymous"
        />
    </Fragment>
    <PageSection>
        <h1 class="text-center font-serif uppercase  text-neutral-950 text-5xl">Resources</h1>
        <Multicard elementMinSize="24rem">
            {
                resources.map((resource) => (
                    <Resourcecard resource={resource}/>
                ))
            }
        </div>
    </PageSection>
</PageLayout>
